#!/usr/bin/env python3
import sys
from CLI.interface import (parse_arguments, handle_benchmarks)
from exit_codes import EXIT_CODE_MISSING_ARGUMENTS, EXIT_CODE_UNEXPECTED_ERROR
from CLI.helpers import (setup_command, validate_required_args)


def main():
    try:
        args = parse_arguments()
        if args.command == "setup":
            setup_command(args)
            return

        if args.command is None and validate_required_args(args):
            handle_benchmarks(args)
        else:
            sys.exit(EXIT_CODE_MISSING_ARGUMENTS)
    except Exception:
        sys.exit(EXIT_CODE_UNEXPECTED_ERROR)


if __name__ == "__main__":
    main()
