#!/usr/bin/env python3
import sys
import argparse
from cli_helpers import (
    cleanup_tag_directory,
    setup_command,
    parse_arguments,
    handle_benchmarks
)

def main():
    args = parse_arguments()
    
    if args.command == "setup":
        setup_command(args)
    elif args.command is None and (args.benchmarks or args.profiles or args.tag or args.count):
        try:
            handle_benchmarks(args)
        except Exception as e:
            print(f"\nError: {e}", file=sys.stderr)
            print("Cleaning up tag directory...")
            cleanup_tag_directory(args.tag)
            sys.exit(1)
    else:
        parser = argparse.ArgumentParser(description='CLI tool for benchmarking Go code with profile analysis')
        parser.print_help()
        sys.exit(1)

if __name__ == "__main__":
    main()
