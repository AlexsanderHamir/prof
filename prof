#!/usr/bin/env python3
import sys
from cli_helpers import (parse_arguments, handle_benchmarks, setup)
from config_manager import ConfigurationError
from utils_benchmark import (validate_required_args, cleanup_tag_directory, BenchmarkBaseError)


def main():
    try:
        args = parse_arguments()

        if args.command == "setup":
            setup(args)

        no_command_present = args.command is None
        if no_command_present and validate_required_args(args):
            try:
                handle_benchmarks(args)
            except (BenchmarkBaseError, ConfigurationError) as e:
                print(f"\nBenchmark Failed: {e}", file=sys.stderr)
                print("Cleaning up tag directory...")

                cleanup_tag_directory(args.tag)
                sys.exit(1)
            except Exception as e:
                print(f"\nUnexpected error: {e}", file=sys.stderr)
                print("Cleaning up tag directory...")

                cleanup_tag_directory(args.tag)
                sys.exit(1)
    except Exception as e:
        print(f"\nUnexpected error: {e}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
