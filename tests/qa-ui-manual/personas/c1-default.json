{
    "version": 1,
    "collection": {
        "defaults": {
            "include_prefixes": [
                "qa-ui-manual"
            ],
            "ignore_functions": [
                "init",
                "TestMain",
                "BenchmarkMain"
            ]
        }
    },
    "track": {
